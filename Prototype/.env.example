# Supabase Configuration (BACKEND-ONLY)
# -------------------------------------------------------------------------
# WARNING: The Service Role Key allows full bypass of Row Level Security.
# - NEVER expose SUPABASE_SERVICE_ROLE_KEY to the React/Vite frontend.
# - NEVER commit your real .env file to version control.
# - SUPABASE_URL must include the protocol (https://).
# -------------------------------------------------------------------------

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage Configuration
SUPABASE_FEED_BUCKET=feeds
SUPABASE_FEED_FILE=capstones-latest.json

# Staging Protection (Optional)
# If set, all POST/PUT/DELETE operations require this key in 'x-admin-key' header.
ADMIN_ACCESS_KEY=your-secret-staging-key
