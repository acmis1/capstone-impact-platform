# Supabase Configuration (BACKEND-ONLY)
# -------------------------------------------------------------------------
# SECURITY WARNING: 
# - SUPABASE_SECRET_KEY (or legacy SUPABASE_SERVICE_ROLE_KEY) allows full bypass of RLS.
# - NEVER expose these keys to the React/Vite frontend or client-side code.
# - NEVER commit your real .env file to version control.
# - SUPABASE_URL must include the protocol (https://).
# -------------------------------------------------------------------------

SUPABASE_URL=

# Only ONE private server key should normally be populated. Prefer SUPABASE_SECRET_KEY.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Staging/Recovery Target Protection Gate
# -------------------------------------------------------------------------
# IMPORTANT: This must be the generated unique project reference subdomain.
# - It is NOT the human-readable Dashboard project name.
# - For example, if your URL is https://abcdefg.supabase.co, the reference is: abcdefg
# - All database/storage writes will fail if this value is missing or mismatching.
SUPABASE_EXPECTED_PROJECT_REF=

# Storage Configuration (For public feed distribution)
SUPABASE_FEED_BUCKET=feeds
SUPABASE_FEED_FILE=capstones-latest.json
SUPABASE_ASSET_BUCKET=project-assets

# Staging Protection (Optional)
# If set, all POST/PUT/DELETE operations require this key in 'x-admin-key' header.
ADMIN_ACCESS_KEY=
