# Supabase Connection URL (Staging project)
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe client keys
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only private database admin keys
# SUPABASE_SECRET_KEY is the new secret key format, while SUPABASE_SERVICE_ROLE_KEY is the legacy JWT format.
# One of these must be populated. The JWT format is preferred to bypass RLS policies cleanly.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Staging Storage Buckets
SUPABASE_DRAFT_BUCKET=project-drafts-private
SUPABASE_PUBLIC_ASSETS_BUCKET=project-public-assets
SUPABASE_PUBLIC_FEEDS_BUCKET=public-feeds
SUPABASE_PUBLIC_FEED_FILE=capstones-latest.json

# Gemini AI Extraction (Staging Assistive Tools)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ASSISTIVE_EXTRACTION_ENABLED=false
